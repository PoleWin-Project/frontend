{
  "name": "polewin",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "dev": "expo start",
    "dev:lan": "expo start --lan",
    "dev:tunnel": "expo start --tunnel",
    "dev:clear": "expo start --clear --lan",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "build": "expo export -p web",
    "clean": "node -e \"const fs=require('fs');['.expo','node_modules'].forEach(p=>{try{fs.rmSync(p,{recursive:true,force:true});}catch{}})\""
  },
