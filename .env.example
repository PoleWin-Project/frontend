# Backend API
# Optionnel : laisser commenté = l'IP du backend est détectée automatiquement
# depuis le serveur Expo (cf. lib/config.ts). Plus besoin de changer l'IP à
# chaque changement de réseau WiFi.
# Décommenter uniquement pour forcer une URL précise (ex: backend distant).
# EXPO_PUBLIC_API_URL=http://localhost:8000/api/v1

# News API - Clé sur https://newsdata.io
EXPO_PUBLIC_NEWS_DATA_API_KEY=

# Auth Google / Apple (requis uniquement pour un development build, pas Expo Go)
# Identifiants OAuth Google : https://console.cloud.google.com/apis/credentials
EXPO_PUBLIC_GOOGLE_CLIENT_ID_WEB=
EXPO_PUBLIC_GOOGLE_CLIENT_ID_IOS=
EXPO_PUBLIC_GOOGLE_CLIENT_ID_ANDROID=
